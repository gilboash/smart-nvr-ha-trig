SNVR_HOST=0.0.0.0
SNVR_PORT=7070
SNVR_DB_PATH=./data/snvr.db
SNVR_SNAPSHOT_DIR=./data/snapshots
SNVR_MODEL_DIR=./config/models
SNVR_LOG_LEVEL=INFO
# Ultralytics device: "cuda", "cuda:0", "cpu", or "auto"
SNVR_DEVICE=auto
# Session signing key — set a long random string in production
SNVR_SESSION_SECRET=
# Override admin password on startup (leave blank to auto-generate on first boot and log it)
SNVR_ADMIN_PASSWORD=
